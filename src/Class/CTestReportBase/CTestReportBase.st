//*********************************************************************
//
//
//*********************************************************************
FUNCTION CTestReportBase::replace
	VAR_INPUT
		pSource 	: ^CHAR;
		pReplace : ^CHAR;
		pData 	: ^CHAR;
	END_VAR
   VAR
   	u32LenSrc : UDINT;
      u32LenRpl : UDINT;
      pBuffer   : ^CHAR;
      pSearch   : ^CHAR;
      buffer    : Array[0..512] of CHAR;
   END_VAR

   if pSource = nil then
      pSource := #m_chBuffer[0];
   end_if;
   
   if pReplace = nil | pData = nil then
      return;
   end_if;
   
   _memset(dest:= #buffer, usByte:= 0, cntr:= sizeof(buffer));
   
   u32LenSrc := clib.StrLen(pSource);
   u32LenRpl := clib.StrLen(pReplace);
   // wir suchen bspw. nach "%1" in "blablaba %1 und noch text"
   // 
   pSearch := clib.StrStr(searchee:= pSource, lookfor:= pReplace);
   
   while pSearch <> nil do
   
      pBuffer := #buffer[0];
      // erstmal alles bis zur Fundstelle kopieren "blablaba "
      _memcpy(ptr1:= pBuffer, ptr2:= pSource,  cntr:= pSearch-pSource);
      pBuffer += (pSearch-pSource);
      // dann den neuen Inhalt einfügen und pSearch um %1 hochzählen
      _memcpy(ptr1:= pBuffer , ptr2:= pData, cntr:= clib.StrLen(pData));
      pBuffer += clib.StrLen(pData);
      pSearch += u32LenRpl;
      // dann den Rest des Quellstrings anhängen
      if (u32LenSrc > pSearch-pSource) then
         _memcpy(ptr1:= pBuffer, ptr2:= pSearch, cntr:= u32LenSrc-(pSearch-pSource));
      end_if;
      
      _memset(dest:=pSource, usByte:= 0, cntr:= u32LenSrc);
      
      _memcpy(ptr1:=pSource, ptr2:=#buffer, cntr:= clib.StrLen(#buffer[0]));
      
      pSearch := clib.StrStr(searchee:= pSource, lookfor:= pReplace);
      
   end_while;

END_FUNCTION

