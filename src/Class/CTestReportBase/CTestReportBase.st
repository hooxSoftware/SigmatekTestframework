//
//
//*********************************************************************
FUNCTION CTestReportBase::endsWith
	VAR_INPUT
		pString 	: ^CHAR;
		pSign 	: ^CHAR;
	END_VAR
	VAR_OUTPUT
		bResult 	: BOOL;
	END_VAR
   VAR
   	s32Size     : UDINT;
      pStringEnd  : ^CHAR;
   END_VAR
   
   s32Size     := 0;
   pStringEnd  := pString;
   bResult     := false;
   
   if pString = nil | pSign = nil then
      return;
   end_if;
   
   s32Size := _strlen(src:= pString);
   if s32Size > 1 then
      s32Size -= 1;
   end_if;
       
   if pStringEnd <> nil then    
      pStringEnd += s32Size;
      if pStringEnd^ = pSign^ then
         bResult := true;
      end_if;
   end_if;

END_FUNCTION
