FUNCTION CTestReportBase::checkDirectory
	VAR_OUTPUT
		eRetcode 	: ERetCode_t;
	END_VAR
   VAR
   	s32Handle : DINT;
      info      : _DDE_INFO;
      buffer    : Array[0..512] of CHAR;
   END_VAR

   eRetcode := ERetCode_t::eFailed;
   
   _memset(dest:= #info, usByte:=0, cntr:=sizeof(_DDE_INFO));
   _memset(dest:= #buffer, usByte:=0, cntr:=sizeof(buffer));
   
   s32Handle :=  File.FindFirstEx(  namepattern  := #m_sFile.aPath[0], 
                                    attr0        := 0, 
                                    attrmask     := 0, 
                                    fileinfo     := #info, 
                                    filename     := #buffer[0], 
                                    maxlength    := _strlen(#m_sFile.aPath[0]));
                       
   if s32Handle >= 0 then
      eRetcode := ERetCode_t::eDone;       
   else   
      if File.CreateDirectory(#m_sFile.aPath[0]) = 0 then
         eRetcode := ERetCode_t::eDone;
      end_if;      
   end_if;
   
   File.FindClose(s32Handle);
   

   
   
END_FUNCTION

