FUNCTION GLOBAL CTestReportBase::create
	VAR_OUTPUT
		eRetcode 	: ERetCode_t;
	END_VAR
   VAR
      eReturn : ERetCode_t;
   END_VAR

   if m_pTestLib = nil then
      eRetcode := eFailed; 
      return;
   end_if;
   
   // read Time and Date for actual file
   System.GetSysTime(#m_sSysTime);
   System.GetSysDate(#m_sSysDate);   
   
   eRetcode := eBusy;

   case m_eState of
   
   eIdle:
   
      m_eState := eOpenFile;
      _memset(dest:= #m_sFile, usByte:= 0, cntr:= sizeof(m_sFile));
   
   eOpenFile:
   
      eReturn := Open();
   
      if eReturn = eDone then
         m_eState := eWriteFile;
      elsif eReturn = eFailed then
         m_eState := eError;
      end_if;
   
   eWriteFile:

      eReturn := BuildFile();
   
      if eReturn = eDone then
         m_eState := eCloseFile;
      elsif eReturn = eFailed then
         m_eState := eError;
      end_if;
   
   eCloseFile:

      eReturn := Close();
   
      if eReturn = eDone then
         m_eState     := eIdle;
         eRetcode     := eDone;
      elsif eReturn = eFailed then
         m_eState := eError;
      end_if;
      
   eError:
   
      eRetcode := eFailed;
   
   end_case;
   
END_FUNCTION

