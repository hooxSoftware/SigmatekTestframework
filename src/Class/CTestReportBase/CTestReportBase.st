FUNCTION VIRTUAL GLOBAL CTestReportBase::Init
   
   if _FirstScan then
   
      m_pTestLib := _LookUpObj(pName:= "TestLib")$^CTestLib;
   
      if m_pTestLib <> nil then
         if m_pTestLib^.registerReport(this) = true then
            Registered  := 1;
         end_if;         
         m_eState    := eIdle;
      end_if;

   end_if;
   
END_FUNCTION

