FUNCTION CTestReportBase::Open
VAR_OUTPUT
   eRetcode 	: ERetCode_t;
END_VAR
VAR
	FileName : Array[0..200] of CHAR;
   u32Size  : UDINT;
END_VAR

   eRetcode := eFailed;
      
   if getFileName(pFileName:= #m_sFile.aName[0], 
                  pFilePath:= #m_sFile.aPath[0]) = eDone then
                  
      u32Size := _strlen(#m_sFile.aPath[0]);                  
                  
      if u32Size > 0 then
         if m_sFile.aPath[ u32Size-1 ] = '\' then
            m_sFile.aPath[ u32Size-1 ] := 0;
         end_if;
      end_if;
                  
      if checkDirectory() = ERetCode_t::eDone then
                  
         _memset( dest   := #FileName, 
                  usByte := 0, 
                  cntr   := sizeof(FileName));     

         _strcat(dest   := #FileName[0], 
                 src    := #m_sFile.aPath[0]);  

         _strcat(dest   := #FileName[0], 
                 src    := "\"); 
                 
         _strcat(dest   := #FileName[0], 
                 src    := #m_sFile.aName[0]);       
                 
         File.FileDelete(#FileName[0]);         

         m_sFile.s32Handle :=  File.FileOpen(filename    := #FileName[0], 
                                               attributes  := (ATT_READ_WRITE or ATT_CREATE_ALWAYS));

         if m_sFile.s32Handle > 0 then
            eRetcode := eDone;
         else
            TRACE_ERR("failed open file!");
         end_if;
      
      else
         TRACE_ERR("failed creating directory!");      
      end_if;
   
   end_if;

END_FUNCTION

