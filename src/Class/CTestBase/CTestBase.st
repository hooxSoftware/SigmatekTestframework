//*********************************************************************
FUNCTION GLOBAL CTestBase::_prepare
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   
   State := eStatePrepare;
   
   _assert.reset();
   
   bRetcode := prepare();

END_FUNCTION

//*********************************************************************
//
//
//*********************************************************************
FUNCTION GLOBAL CTestBase::_execute
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   
   if State = eStatePrepare then
      m_u32Start := ops.tAbsolute;
      m_u32End   := 0;
      State      := eStateExecute;
   end_if;
   
   bRetcode := execute();

END_FUNCTION

//*********************************************************************
//
//
//*********************************************************************
FUNCTION GLOBAL CTestBase::_cleanup
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   
   if m_u32End = 0 then
      m_u32End := ops.tAbsolute;
   end_if;
   
   case _assert.State of
   
   CAssert::EState_t::ePassed:
      State := eStatePassed;
   
   CAssert::EState_t::eFailed:
      State := eStateFailed;
   
   CAssert::EState_t::eFailedFatal:
      State := eStateFailedFatal;
      
   end_case;
   
   bRetcode := cleanUp();

END_FUNCTION

