FUNCTION GLOBAL CTestBase::isSelected
	VAR_OUTPUT
		bRetcode 	: DINT;
	END_VAR
   
   if Deactivate = 1 then
      State    := eStateSkipped;
   end_if;
   
   bRetcode := (State <> eStateSkipped); 
   
END_FUNCTION

