FUNCTION GLOBAL CTestSuite::getStatistics
	VAR_INPUT
		pVariable 	: ^SStatistic_t;
	END_VAR
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   
   bRetcode := false;
   
   if pVariable = nil then
      return;   
   end_if;
   
   pVariable^.udElapsedTime := m_udElapsedTime;
   pVariable^.NbPassed      := NbPassed;
   pVariable^.NbRun         := NbRun;
   pVariable^.NbFailed      := NbFailed;
   pVariable^.NbSkipped     := NbSkipped;
   
   bRetcode := true;

END_FUNCTION

