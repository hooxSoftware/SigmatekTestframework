//*****************************************************************************
FUNCTION GLOBAL CTestSuite::registerTest
	VAR_INPUT
		pTestCase 	: ^CTestBase;
	END_VAR
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   
   bRetcode := false;
   
   if pTestCase <> nil then
      
      if m_TestList.getElementSize() = 0 then
         m_TestList.create(sizeof(^CTestBase));
      end_if;
      
      m_TestList.insert((#pTestCase)$CLinkedList::Element_t);
      
      NbTests += 1;
      
      bRetcode := true;
      
   end_if;

END_FUNCTION

//*****************************************************************************
//
//
//
//
//*****************************************************************************
FUNCTION GLOBAL CTestSuite::execute
	VAR_INPUT
		eCommand 	: CTestLib::ECommand_t;
	END_VAR
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR
   VAR
   	pTestCase  : ^CTestBase;
      TestId     : CTestBase::ABuffer_t;
      eTestState : CTestBase::ETestState_t;
   END_VAR

   bRetcode    := false;
   pTestCase   := nil;
   eTestState  := CTestBase::eStateError;
   
   case State of

   CTestSuite::eStateIdle:
   
      if eCommand = CTestLib::eCmdRun then
      
         if Deactivate = true then
            bRetcode  := true;
            NbPassed  := 0;
            NbFailed  := 0;
            NbRun     := 0;            
            NbSkipped := to_udint(m_TestList.Size.Read()); 
            return;
         end_if;
      
         if m_TestList.empty() = false then
         
            m_itActTestCase := m_TestList.first();
            State           := CTestSuite::eStatePrepare;
            NbPassed        := 0;
            NbFailed        := 0;
            NbRun           := 0;
            NbSkipped       := 0;
            m_udStartTime   := ops.tAbsolute;
            
         else
         
            State := CTestSuite::eStateError;
            
         end_if;
         
      end_if;
   
   CTestSuite::eStatePrepare:
   
      pTestCase := getElement(m_itActTestCase);
   
      if pTestCase <> nil then
      
         if pTestCase^.isSelected() = true then
      
            if pTestCase^._prepare() then
               pTestCase^.getTestId(#TestId);
               m_pLib^.setActualTestId(#TestId);
               State := CTestSuite::eStateExecute;
            end_if;
         
         else
            NbSkipped +=1; 
            State      := CTestSuite::eStateNextTest;
            
         end_if;
         
      else
         State := CTestSuite::eStateError;   
      end_if;
      
   CTestSuite::eStateExecute:
   
      pTestCase := getElement(m_itActTestCase);
   
      if pTestCase <> nil then
      
         if pTestCase^._execute() then
            
            State := CTestSuite::eStateCleanUp;
            
         end_if;
         
      else
         State := CTestSuite::eStateError;
      end_if;
      
   CTestSuite::eStateCleanUp:
   
      pTestCase := getElement(m_itActTestCase);
   
      if pTestCase <> nil then
      
         if pTestCase^._cleanUp() then
         
            NbRun += 1;
            
            eTestState := pTestCase^.getTestState();
            
            case eTestState of

            CTestBase::eStateSkipped:
            
               NbSkipped += 1;
            
            CTestBase::eStatePassed:
            
               NbPassed += 1;
               
            CTestBase::eStateFailed:
            
               NbFailed += 1;
               
            CTestBase::eStateFailedFatal:
            
               NbFailed          += 1; 
               m_bFatal          := true;
               
            end_case;
            
            State := CTestSuite::eStateNextTest;
            
         end_if;
         
      else
         State := CTestSuite::eStateError;   
      end_if;

   CTestSuite::eStateNextTest:
   
      m_itActTestCase := m_TestList.next(m_itActTestCase);
      
      if m_itActTestCase <> nil & m_bFatal = false then
         State := CTestSuite::eStatePrepare;
      else
         State             := CTestSuite::eStateIdle;
         m_udElapsedTime   := ops.tAbsolute - m_udStartTime;
         bRetcode          := true;
      end_if;
      
   CTestSuite::eStateError:
      
      bRetcode          := true;
      
      if eCommand = CTestLib::eCmdReset then
         State := CTestSuite::eStateIdle;
      end_if;
      
   end_case;

END_FUNCTION

