FUNCTION VIRTUAL GLOBAL CTestSuite::Init

   if _FirstScan then
   
      State := CTestSuite::eStateInit; 
      
      m_pLib := _LookUpObj(pName:= "TestLib")$^CTestLib;
   
      if m_pLib <> nil then
         if m_pLib^.registerSuite(this) = false then
            State := CTestSuite::eStateError;
         else
            State := CTestSuite::eStateIdle; 
         end_if;
      end_if;

   end_if;
   
END_FUNCTION
 
