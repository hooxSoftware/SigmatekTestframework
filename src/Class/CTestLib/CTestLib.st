//
//*********************************************************************
FUNCTION GLOBAL CTestLib::registerReport
	VAR_INPUT
		pReport 	: ^CTestreportBase;
	END_VAR
	VAR_OUTPUT
		bRetcode 	: BOOL;
	END_VAR

   bRetcode    := false;
   
   if pReport = nil then
      return;
   end_if;
   // interne Elemente nicht registrieren
   if JUnitReport.compare(pReport) then
      return;
   end_if;
   
   if m_u8Reports = 9 then
      return;
   end_if;
   
   m_aReports[m_u8Reports] := pReport;
   m_u8Reports += 1;

END_FUNCTION

