//*********************************************************************
//
//
//*********************************************************************
FUNCTION CTestLib::Cycle
   VAR
      sStatistic : CTestSuite::SStatistic_t;
      eReportState : CTestReportBase::ERetCode_t;
   END_VAR
   
   LastTestID := m_TestRunID.Data;
   
   m_MaxIndex := TestLib_GetSize();
   
   case eState of

   CTestLib::eStateIdle:
   
      if Command = eCmdRun then
         if m_TestSuites.empty() = false then
            m_itActSuite := m_TestSuites.first();
            m_pActSuite  := getElement(m_itActSuite);
            if m_pActSuite <> nil then
               m_pActSuite^.Prepare();
               eState       := CTestLib::eStateExecute;
               NbPassed     := 0;
               NbFailed     := 0;
               NbRun        := 0;
               NbSkipped    := 0;
               m_TestRunID.Data.Write(m_TestRunID.Data+1);
               m_udStartTime := ops.tAbsolute;
            else
               Command  := eCmdStop;
               eState   := CTestLib::eStateError;            
            end_if;
         else
            if m_pExternalTest <> nil then
               m_pExternalTest^.Prepare();
               eState       := CTestLib::eStateExecute;
            else
               Command  := eCmdStop;
               eState := CTestLib::eStateError;            
            end_if;

         end_if;
      end_if;
      
      if Command = eCmdCreateFile then
         m_u8ReportIndex := 0;
         eState          := CTestLib::eStateNextReport;
      end_if;
   
   CTestLib::eStateExecute:

      if m_pExternalTest <> nil then
         if m_pExternalTest^.execute() = true then
            m_pExternalTest^.cleanUp();
            eState      := eStateCreateCoverage;
         end_if;
      else
            
         if m_pActSuite <> nil then
         
            if m_pActSuite^.isSelected()  = true then
            
               if m_pActSuite^.execute(Command) = true then
               
                  eState := CTestLib::eStateNextSuite;
                  
                  if m_pActSuite^.getStatistics(#sStatistic) = true then
                     NbRun           += sStatistic.NbRun;
                     NbPassed        += sStatistic.NbPassed;
                     NbFailed        += sStatistic.NbFailed;
                     NbSkipped       += sStatistic.NbSkipped;
                  end_if;
                  
               end_if;
               
            else
               NbSkipped += 1;
               eState    := CTestLib::eStateNextSuite;
               
            end_if;
            
         else
            eState := CTestLib::eStateError;   
         end_if;
         
      end_if;

   CTestLib::eStateNextSuite:
   
      m_itActSuite := m_TestSuites.next(m_itActSuite);
      
      if m_itActSuite <> nil then
         m_pActSuite := getElement(m_itActSuite);   
         if m_pActSuite <> nil then
            m_pActSuite^.Prepare();
            eState      := CTestLib::eStateExecute;
         else
            eState      := CTestLib::eStateError;
         end_if;
      else
         m_pActSuite := nil;
         //Testlauf fertig, Testid löschen
         m_strActualTest.Clear();      
         eState      := CTestLib::eStateCreateJUnit;
         Command     := eCmdStop;
                 
         m_udElapsedTime   := ops.tAbsolute - m_udStartTime;         
      end_if;
      
   CTestLib::eStateCreateJUnit: 
   
      eReportState := JUnitReport.create();

      if eReportState = CTestReportBase::eFailed then
         eState   := eStateError;
      elsif eReportState = CTestReportBase::eDone then
         if m_pClassList = nil then
            eState      := eStateIdle;
            Command     := eCmdStop;      
         else
            eState      := eStateCreateCoverage;
         end_if;
      end_if;
 
   CTestLib::eStateCreateCoverage: 
   
      if m_pClassList <> nil then
         eReportState := CodeCoverage.create();
         if eReportState = CTestReportBase::eFailed then
            eState      := CTestLib::eStateError;
         elsif eReportState = CTestReportBase::eDone then
            eState      := CTestLib::eStateIdle;
            Command     := eCmdStop;
         end_if;
      end_if;
      
   CTestLib::eStateNextReport: 
        
     m_pReport       := m_aReports[m_u8ReportIndex];
     m_u8ReportIndex +=1;
     eState          := CTestLib::eStateCreateReport;
     
   CTestLib::eStateCreateReport:
         
      if m_pReport <> nil then
         eReportState := m_pReport^.create(); 
      else
         eState      := CTestLib::eStateIdle;
      end_if;
      
      if eReportState = CTestReportBase::eFailed then
         eState   := CTestLib::eStateError;
      elsif eReportState = CTestReportBase::eDone then
         eState      := CTestLib::eStateIdle;
         Command     := eCmdStop;
      end_if;
            
   CTestLib::eStateError:
      
      if Command = eCmdReset then
         Report.reset();
         eState := CTestLib::eStateIdle;
      end_if;
      
   end_case;
   
END_FUNCTION

