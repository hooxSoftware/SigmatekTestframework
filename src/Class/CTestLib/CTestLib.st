		pResult 	: ^CTestSuite;
	END_VAR

   m_TestSuites.getElement(iterator , (#pResult)$CLinkedList::Element_t);

END_FUNCTION

//*********************************************************************
//
//
//*********************************************************************
FUNCTION GLOBAL CTestLib::setActualTestId
	VAR_INPUT
		pTestId 	: ^CTestBase::ABuffer_t;
	END_VAR
   
   if pTestId = nil then
      return;
   end_if;
   
   memory.MemSet(pMemptr   := #m_ActualTestId, 
                 fill      := 0, 
                 size      := sizeof(CTestBase::ABuffer_t));
                 
   memory.MemCpy( dest     := #m_ActualTestId, 
                  source   := pTestId, 
                  size     := sizeof(CTestBase::ABuffer_t));
                  
   m_strActualTest.Clear();
   m_strActualTest.WriteDataOff(udLen:= _StrLen(src:= #m_ActualTestId[0]), 
                                udOff:= 0, 
                                pData:= #m_ActualTestId[0]);

END_FUNCTION

//*********************************************************************
//
//
//*********************************************************************
FUNCTION CTestLib::InitializeMemory
VAR
	u32Index  : UDINT;
   pClass    : ^UDINT;
   pLineInfo : ^void;
   u32Size   : UDINT;
END_VAR

   Command := eCmdStop;
   
   if Classes > 0 then
      u32Size := Classes*sizeof(AClassData_t);
      // Speicher für Klassenliste reservieren
      m_pClassList$^void := memory.Malloc(u32Size);
      if (m_pClassList <> nil) then
         memory.MemSet(m_pClassList, 0, u32Size);   
      end_if;
      
      if m_pClassList = nil then
         TRACE_ERR("InitializeMemory failed to create Classlist!");
         eState := CTestLib::EStateError;
         return;
      end_if;
      
      pClass  := m_pClassList;
      u32Size := Lines*sizeof(SLine_t);
      // Speicher für Zeilen in den Klassen reservieren
      for u32Index := 0 to Classes-1 do   
         pLineInfo := memory.Malloc(u32Size);
         
         if (pLineInfo <> nil) then
            memory.MemSet(pLineInfo, 0, u32Size);
            pClass^ := pLineInfo$UDINT;
         else            
            TRACE_ERR("InitializeMemory failed to create Line Memory!");
            eState   := CTestLib::EStateError;
            u32Index := Classes;
         end_if;
         
         pClass  += sizeof(UDINT);
      end_for;
      
      TestLib_Init(m_pClassList, Classes, Lines);
   end_if;
      
END_FUNCTION








